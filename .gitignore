# data/processed/: tracked by DVC. Ignore the binary blobs but keep the
# .dvc pointer files and DVC-managed .gitignore so the layout is
# reproducible from a fresh clone with `dvc pull` (or by rebuilding from
# raw with the loader).
data/processed/*
!data/processed/.gitignore
!data/processed/*.dvc
mlruns/
mlflow_artifacts/

