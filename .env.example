# =============================================================================
# Hipica-ML — environment template
# Copy to `.env` and adjust as needed:   cp .env.example .env
# =============================================================================

# ---- Postgres ----------------------------------------------------------------
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

# Application database (created by docker/postgres/init.sql)
RACING_DB=racing

# ---- MLflow ------------------------------------------------------------------
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_NAME=trifecta-classifier
MODEL_STAGE=Production

# ---- API ---------------------------------------------------------------------
API_PORT=8000
API_WORKERS=2

# ---- Streamlit ---------------------------------------------------------------
STREAMLIT_PORT=8501

# ---- Scraper -----------------------------------------------------------------
# Public mobile REST endpoint behind hipica.maronas.com.uy (discovered from
# /bundles/app -> ServicesURLs.Https.XTurfRestServicesURL).
MARONAS_REST_URL=https://mobile-rest-services-v3.azurewebsites.net/XTurfRestService.svc
MARONAS_RESOURCES_URL=https://mobile-rest-services-v3.azurewebsites.net/XTurfResourcesService.svc
SCRAPER_RACETRACK_ID=1            # 1=Maroñas, 13=Las Piedras
SCRAPER_DATE_FROM=2018-01-01
SCRAPER_DATE_TO=2026-06-01
SCRAPER_RAW_DIR=data/raw
SCRAPER_HTTP_TIMEOUT=60
SCRAPER_MAX_WORKERS=4
